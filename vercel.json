{
  "redirects": [
    { "source": "/ae", "destination": "/auto-entrepreneur", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/devis/:path*", "destination": "https://provision-backend-production.up.railway.app/devis/:path*" },
    { "source": "/guides", "destination": "/guides/index.html" },
    { "source": "/guides/", "destination": "/guides/index.html" },
    { "source": "/intermittent", "destination": "/intermittent.html" },
    { "source": "/auto-entrepreneur", "destination": "/auto-entrepreneur.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
